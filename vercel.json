{
  "version": 2,
  "functions": {
    "api/**/*.php": { "runtime": "@vercel/php" }
  },
  "rewrites": [
    { "source": "/admin/(.*\\.php)", "destination": "/api/admin/$1" },
    { "source": "/user/(.*\\.php)", "destination": "/api/user/$1" },
    { "source": "/(.*\\.php)", "destination": "/api/$1" },
    { "source": "/", "destination": "/api/index.php" }
  ]
}
