{
  "version": 2,
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.7.2"
    }
  },
  "rewrites": [
    { "source": "/admin/(.*)", "destination": "/api/admin/$1" },
    { "source": "/user/(.*)", "destination": "/api/user/$1" },
    { "source": "/database/(.*)", "destination": "/api/database/$1" },
    { "source": "/", "destination": "/api/index.php" },
    { "source": "/(.*)", "destination": "/api/$1" }
  ]
}
